---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Proyecto – SprintDev Bank">

<section class="py-12">

  <!-- Header -->
  <div class="mb-12">
    <a href="/evidencias" class="text-blue-600 text-sm hover:underline">← Evidencias</a>
    <h1 class="text-4xl font-bold mt-4 bg-gradient-to-r from-violet-600 to-fuchsia-500 bg-clip-text text-transparent">
      SprintDev Bank
    </h1>
    <p class="mt-3 text-gray-600 max-w-3xl">
      Sistema integral de gestión bancaria con detección de fraude en tiempo real,
      desarrollado en PostgreSQL como proyecto final de Bases de Datos 1 —
      Universidad El Bosque.
    </p>
  </div>

  <!-- Ficha técnica -->
  <div class="grid md:grid-cols-4 gap-4 mb-14">
    <div class="rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
      <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Motor</p>
      <p class="text-lg font-bold text-gray-800">PostgreSQL 16</p>
    </div>
    <div class="rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
      <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Tablas</p>
      <p class="text-lg font-bold text-gray-800">15 entidades</p>
    </div>
    <div class="rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
      <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Registros</p>
      <p class="text-lg font-bold text-gray-800">+500 datos</p>
    </div>
    <div class="rounded-2xl border border-gray-200 bg-white px-5 py-4 shadow-sm">
      <p class="text-xs text-gray-400 uppercase tracking-wider mb-1">Materia</p>
      <p class="text-lg font-bold text-gray-800">Bases de Datos 1</p>
    </div>
  </div>

  <!-- Descripción del sistema -->
  <article class="mb-14 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
    <div class="bg-gradient-to-r from-violet-50 to-fuchsia-50 border-b border-gray-200 px-8 py-6">
      <h2 class="text-2xl font-bold">Descripción del sistema</h2>
    </div>
    <div class="px-8 py-8 grid md:grid-cols-2 gap-8 text-gray-600 text-sm leading-relaxed">
      <div>
        <h3 class="font-semibold text-gray-800 mb-2">Objetivo</h3>
        <p>
          SprintDev Bank es una base de datos relacional diseñada para gestionar las
          operaciones de un banco digital: clientes, productos financieros (cuentas,
          tarjetas y créditos), transacciones y un motor de detección de fraude basado
          en reglas configurables con diferentes niveles de severidad.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-800 mb-2">Decisiones de diseño</h3>
        <ul class="space-y-1 list-disc list-inside">
          <li>Herencia lógica en <code>producto_financiero</code> con tablas hijas.</li>
          <li>Autorrelación en <code>transaccion</code> para manejar reversas.</li>
          <li>Tabla pivote <code>alerta_transaccion</code> para relación N:M fraude.</li>
          <li>Tipos nativos: <code>BOOLEAN</code>, <code>NUMERIC</code>, <code>TIMESTAMP</code>.</li>
          <li>Constraints <code>CHECK</code> en todos los campos de enumeración.</li>
        </ul>
      </div>
    </div>
  </article>

  <!-- Arquitectura de tablas -->
  <article class="mb-14 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
    <div class="bg-gradient-to-r from-violet-50 to-fuchsia-50 border-b border-gray-200 px-8 py-6">
      <h2 class="text-2xl font-bold">Arquitectura — Módulos del sistema</h2>
    </div>
    <div class="px-8 py-8 grid md:grid-cols-2 lg:grid-cols-3 gap-5">

      <!-- Tablas maestras -->
      <div class="rounded-2xl border border-violet-200 bg-violet-50 p-5">
        <p class="text-xs font-bold uppercase tracking-wider text-violet-500 mb-3">Tablas maestras</p>
        <div class="space-y-2">
          <div class="bg-white rounded-xl px-4 py-3 border border-violet-100">
            <p class="font-bold text-violet-800 text-xs">CLIENTE</p>
            <p class="text-violet-600 text-xs font-mono">PK: id_cliente</p>
            <p class="text-gray-400 text-xs mt-1">50 registros · estado: activo / bloqueado / investigacion</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-violet-100">
            <p class="font-bold text-violet-800 text-xs">EMPLEADO</p>
            <p class="text-violet-600 text-xs font-mono">PK: id_empleado</p>
            <p class="text-gray-400 text-xs mt-1">50 registros · cajero, analista, supervisor…</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-violet-100">
            <p class="font-bold text-violet-800 text-xs">CANAL</p>
            <p class="text-violet-600 text-xs font-mono">PK: id_canal</p>
            <p class="text-gray-400 text-xs mt-1">web · app · cajero · oficina</p>
          </div>
        </div>
      </div>

      <!-- Productos financieros -->
      <div class="rounded-2xl border border-blue-200 bg-blue-50 p-5">
        <p class="text-xs font-bold uppercase tracking-wider text-blue-500 mb-3">Productos financieros</p>
        <div class="space-y-2">
          <div class="bg-white rounded-xl px-4 py-3 border border-blue-100">
            <p class="font-bold text-blue-800 text-xs">PRODUCTO_FINANCIERO</p>
            <p class="text-blue-600 text-xs font-mono">PK: id_producto</p>
            <p class="text-gray-400 text-xs mt-1">Tabla padre — herencia lógica</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-blue-100">
            <p class="font-bold text-blue-800 text-xs">CUENTA</p>
            <p class="text-blue-600 text-xs font-mono">PK/FK: id_producto</p>
            <p class="text-gray-400 text-xs mt-1">ahorro · corriente · saldo ≥ 0</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-blue-100">
            <p class="font-bold text-blue-800 text-xs">TARJETA</p>
            <p class="text-blue-600 text-xs font-mono">PK/FK: id_producto</p>
            <p class="text-gray-400 text-xs mt-1">débito · crédito · cupo + vencimiento</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-blue-100">
            <p class="font-bold text-blue-800 text-xs">CREDITO</p>
            <p class="text-blue-600 text-xs font-mono">PK/FK: id_producto</p>
            <p class="text-gray-400 text-xs mt-1">monto, saldo pendiente, tasa interés</p>
          </div>
        </div>
      </div>

      <!-- Fraude -->
      <div class="rounded-2xl border border-rose-200 bg-rose-50 p-5">
        <p class="text-xs font-bold uppercase tracking-wider text-rose-500 mb-3">Detección de fraude</p>
        <div class="space-y-2">
          <div class="bg-white rounded-xl px-4 py-3 border border-rose-100">
            <p class="font-bold text-rose-800 text-xs">REGLA_FRAUDE</p>
            <p class="text-rose-600 text-xs font-mono">PK: id_regla</p>
            <p class="text-gray-400 text-xs mt-1">frecuencia · monto_umbral · canal_inusual…</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-rose-100">
            <p class="font-bold text-rose-800 text-xs">ALERTA_FRAUDE</p>
            <p class="text-rose-600 text-xs font-mono">PK: id_alerta</p>
            <p class="text-gray-400 text-xs mt-1">severidad: baja / media / alta / critica</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-rose-100">
            <p class="font-bold text-rose-800 text-xs">ALERTA_TRANSACCION</p>
            <p class="text-rose-600 text-xs font-mono">PK: id_alerta + id_transaccion</p>
            <p class="text-gray-400 text-xs mt-1">Tabla pivote N:M</p>
          </div>
        </div>
      </div>

      <!-- Transacciones -->
      <div class="rounded-2xl border border-green-200 bg-green-50 p-5">
        <p class="text-xs font-bold uppercase tracking-wider text-green-500 mb-3">Transacciones</p>
        <div class="space-y-2">
          <div class="bg-white rounded-xl px-4 py-3 border border-green-100">
            <p class="font-bold text-green-800 text-xs">TRANSACCION</p>
            <p class="text-green-600 text-xs font-mono">PK: id_transaccion</p>
            <p class="text-gray-400 text-xs mt-1">Autorrelación para reversas · es_fallida BOOLEAN</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-green-100">
            <p class="font-bold text-green-800 text-xs">ESTADO_TRANSACCION</p>
            <p class="text-green-600 text-xs font-mono">PK: id_estado_transaccion</p>
            <p class="text-gray-400 text-xs mt-1">pendiente · aplicada · rechazada · reversada</p>
          </div>
        </div>
      </div>

      <!-- Auditoría -->
      <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5">
        <p class="text-xs font-bold uppercase tracking-wider text-amber-500 mb-3">Auditoría y estados</p>
        <div class="space-y-2">
          <div class="bg-white rounded-xl px-4 py-3 border border-amber-100">
            <p class="font-bold text-amber-800 text-xs">EVENTO_AUDITORIA</p>
            <p class="text-amber-600 text-xs font-mono">PK: id_evento</p>
            <p class="text-gray-400 text-xs mt-1">Trazabilidad: cliente / empleado / sistema</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-amber-100">
            <p class="font-bold text-amber-800 text-xs">ESTADO_PRODUCTO</p>
            <p class="text-amber-600 text-xs font-mono">PK: id_estado_producto</p>
            <p class="text-gray-400 text-xs mt-1">activo · bloqueado · cancelado</p>
          </div>
          <div class="bg-white rounded-xl px-4 py-3 border border-amber-100">
            <p class="font-bold text-amber-800 text-xs">ESTADO_ALERTA</p>
            <p class="text-amber-600 text-xs font-mono">PK: id_estado_alerta</p>
            <p class="text-gray-400 text-xs mt-1">abierta · en_revision · cerrada</p>
          </div>
        </div>
      </div>

    </div>
  </article>

  <!-- Diagrama MER -->
  <article class="mb-14 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
    <div class="bg-gradient-to-r from-violet-50 to-fuchsia-50 border-b border-gray-200 px-8 py-6">
      <h2 class="text-2xl font-bold">Diagrama Entidad-Relación</h2>
      <p class="text-gray-500 text-sm mt-1">Modelo relacional completo de SprintDev Bank.</p>
    </div>
    <div class="px-8 py-8 overflow-x-auto">
      <div id="mer-sprintdev"></div>
    </div>
  </article>

  <!-- Scripts SQL -->
  <article class="mb-14 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
    <div class="bg-gradient-to-r from-violet-50 to-fuchsia-50 border-b border-gray-200 px-8 py-6">
      <h2 class="text-2xl font-bold">Scripts SQL entregados</h2>
    </div>
    <div class="px-8 py-8 grid md:grid-cols-3 gap-5">

      <div class="rounded-2xl border border-violet-200 bg-violet-50 p-5">
        <p class="text-2xl mb-3">🏗️</p>
        <p class="font-bold text-sm font-mono text-violet-800 mb-2">Creacion_de_la_DB.sql</p>
        <p class="text-gray-600 text-xs leading-relaxed mb-4">
          Creación de la base de datos bosquebank con 15 tablas, llaves primarias,
          foráneas, constraints CHECK y UNIQUE, e índices de rendimiento.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">DROP/CREATE</span>
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">BIGSERIAL</span>
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">FK / CHECK</span>
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">INDEX</span>
        </div>
      </div>

      <div class="rounded-2xl border border-blue-200 bg-blue-50 p-5">
        <p class="text-2xl mb-3">📦</p>
        <p class="font-bold text-sm font-mono text-blue-800 mb-2">Insert_de_datos.sql</p>
        <p class="text-gray-600 text-xs leading-relaxed mb-4">
          Datos de prueba: 50 clientes, 50 empleados, 25 reglas de fraude, productos
          financieros, transacciones y alertas con variedad de estados y canales.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">50 clientes</span>
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">50 empleados</span>
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">25 reglas</span>
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">Alertas</span>
        </div>
      </div>

      <div class="rounded-2xl border border-green-200 bg-green-50 p-5">
        <p class="text-2xl mb-3">🔄</p>
        <p class="font-bold text-sm font-mono text-green-800 mb-2">Actualizacion_de_Ids.sql</p>
        <p class="text-gray-600 text-xs leading-relaxed mb-4">
          Bloque PL/pgSQL que recorre las columnas SERIAL y resetea cada secuencia
          al MAX(id) + 1, evitando conflictos al insertar nuevos registros.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">PL/pgSQL</span>
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">BIGSERIAL</span>
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">setval()</span>
          <span class="text-xs bg-white border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">information_schema</span>
        </div>
      </div>

    </div>
  </article>

  <!-- Fragmentos DDL -->
  <article class="mb-14 rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
    <div class="bg-gradient-to-r from-violet-50 to-fuchsia-50 border-b border-gray-200 px-8 py-6">
      <h2 class="text-2xl font-bold">Fragmentos clave del DDL</h2>
      <p class="text-gray-500 text-sm mt-1">Decisiones técnicas destacadas en la creación del esquema.</p>
    </div>
    <div class="px-8 py-8 space-y-6">

      <div>
        <p class="text-sm font-semibold text-gray-700 mb-2">
          Herencia lógica — <code>producto_financiero</code> como tabla padre
        </p>
        <div class="bg-gray-900 rounded-xl p-5 font-mono text-xs leading-6 overflow-x-auto">
          <p><span class="text-blue-400">CREATE TABLE</span> <span class="text-green-300">producto_financiero</span> (</p>
          <p class="ml-4 text-green-300">id_producto     <span class="text-yellow-300">BIGSERIAL PRIMARY KEY</span>,</p>
          <p class="ml-4 text-green-300">id_cliente      <span class="text-yellow-300">BIGINT NOT NULL</span>,</p>
          <p class="ml-4 text-green-300">numero_producto <span class="text-yellow-300">VARCHAR(30) NOT NULL UNIQUE</span>,</p>
          <p class="ml-4"><span class="text-blue-400">CONSTRAINT</span> <span class="text-green-300">fk_producto_cliente</span> <span class="text-blue-400">FOREIGN KEY</span> <span class="text-green-300">(id_cliente)</span></p>
          <p class="ml-8"><span class="text-blue-400">REFERENCES</span> <span class="text-green-300">cliente (id_cliente)</span></p>
          <p class="text-green-300">);</p>
          <br>
          <p><span class="text-blue-400">CREATE TABLE</span> <span class="text-green-300">cuenta</span> (</p>
          <p class="ml-4 text-green-300">id_producto  <span class="text-yellow-300">BIGINT PRIMARY KEY</span>, <span class="text-gray-500">-- comparte PK con padre</span></p>
          <p class="ml-4 text-green-300">tipo_cuenta  <span class="text-yellow-300">VARCHAR(20) NOT NULL</span>,</p>
          <p class="ml-4 text-green-300">saldo_actual <span class="text-yellow-300">NUMERIC(15,2) NOT NULL DEFAULT 0</span>,</p>
          <p class="ml-4"><span class="text-blue-400">CONSTRAINT</span> <span class="text-green-300">ck_cuenta_tipo</span> <span class="text-blue-400">CHECK</span></p>
          <p class="ml-8 text-green-300">(tipo_cuenta <span class="text-blue-400">IN</span> (<span class="text-orange-300">'ahorro'</span>, <span class="text-orange-300">'corriente'</span>)),</p>
          <p class="ml-4"><span class="text-blue-400">CONSTRAINT</span> <span class="text-green-300">fk_cuenta_producto</span> <span class="text-blue-400">FOREIGN KEY</span> <span class="text-green-300">(id_producto)</span></p>
          <p class="ml-8"><span class="text-blue-400">REFERENCES</span> <span class="text-green-300">producto_financiero (id_producto)</span> <span class="text-blue-400">ON DELETE CASCADE</span></p>
          <p class="text-green-300">);</p>
        </div>
      </div>

      <div>
        <p class="text-sm font-semibold text-gray-700 mb-2">
          Autorrelación en <code>transaccion</code> para manejo de reversas
        </p>
        <div class="bg-gray-900 rounded-xl p-5 font-mono text-xs leading-6 overflow-x-auto">
          <p><span class="text-blue-400">CREATE TABLE</span> <span class="text-green-300">transaccion</span> (</p>
          <p class="ml-4 text-green-300">id_transaccion          <span class="text-yellow-300">BIGSERIAL PRIMARY KEY</span>,</p>
          <p class="ml-4 text-green-300">id_transaccion_original <span class="text-yellow-300">BIGINT</span>, <span class="text-gray-500">-- NULL si no es reversa</span></p>
          <p class="ml-4 text-green-300">es_fallida              <span class="text-yellow-300">BOOLEAN NOT NULL DEFAULT FALSE</span>,</p>
          <p class="ml-4 text-green-300">monto                   <span class="text-yellow-300">NUMERIC(15,2) NOT NULL</span>,</p>
          <p class="ml-4"><span class="text-blue-400">CONSTRAINT</span> <span class="text-green-300">fk_transaccion_original</span> <span class="text-blue-400">FOREIGN KEY</span></p>
          <p class="ml-8 text-green-300">(id_transaccion_original) <span class="text-blue-400">REFERENCES</span> transaccion (id_transaccion),</p>
          <p class="ml-4"><span class="text-blue-400">CONSTRAINT</span> <span class="text-green-300">ck_transaccion_monto</span> <span class="text-blue-400">CHECK</span> <span class="text-green-300">(monto &gt; 0),</span></p>
          <p class="ml-4"><span class="text-blue-400">CONSTRAINT</span> <span class="text-green-300">ck_origen_destino</span> <span class="text-blue-400">CHECK</span></p>
          <p class="ml-8 text-green-300">(id_producto_origen <span class="text-blue-400">IS NOT NULL OR</span> id_producto_destino <span class="text-blue-400">IS NOT NULL</span>)</p>
          <p class="text-green-300">);</p>
        </div>
      </div>

      <div>
        <p class="text-sm font-semibold text-gray-700 mb-2">
          PL/pgSQL — Reset automático de secuencias SERIAL
        </p>
        <div class="bg-gray-900 rounded-xl p-5 font-mono text-xs leading-6 overflow-x-auto">
          <p><span class="text-blue-400">DO</span> <span class="text-orange-300">$$</span></p>
          <p><span class="text-blue-400">DECLARE</span> <span class="text-green-300">r RECORD</span>;</p>
          <p><span class="text-blue-400">BEGIN</span></p>
          <p class="ml-4"><span class="text-blue-400">FOR</span> <span class="text-green-300">r</span> <span class="text-blue-400">IN</span> (</p>
          <p class="ml-8"><span class="text-blue-400">SELECT</span> <span class="text-green-300">table_name, column_name, column_default</span></p>
          <p class="ml-8"><span class="text-blue-400">FROM</span> <span class="text-green-300">information_schema.columns</span></p>
          <p class="ml-8"><span class="text-blue-400">WHERE</span> <span class="text-green-300">column_default</span> <span class="text-blue-400">LIKE</span> <span class="text-orange-300">'nextval%'</span></p>
          <p class="ml-8"><span class="text-blue-400">AND</span> <span class="text-green-300">table_schema = </span><span class="text-orange-300">'public'</span>)</p>
          <p class="ml-4"><span class="text-blue-400">LOOP</span></p>
          <p class="ml-8"><span class="text-blue-400">EXECUTE</span> <span class="text-orange-300">'SELECT setval(..., COALESCE((SELECT MAX('</span></p>
          <p class="ml-12 text-green-300">|| r.column_name || <span class="text-orange-300">') FROM '</span> || r.table_name || <span class="text-orange-300">'), 0) + 1, false)'</span>;</p>
          <p class="ml-4"><span class="text-blue-400">END LOOP</span>;</p>
          <p><span class="text-blue-400">END</span> <span class="text-orange-300">$$</span>;</p>
        </div>
      </div>

    </div>
  </article>

  <!-- Reflexión -->
  <article class="rounded-3xl border border-gray-200 bg-white shadow-sm overflow-hidden">
    <div class="bg-gradient-to-r from-violet-50 to-fuchsia-50 border-b border-gray-200 px-8 py-6">
      <h2 class="text-2xl font-bold">Reflexión — E-R, Normalización y Diseño</h2>
    </div>
    <div class="px-8 py-8 grid md:grid-cols-2 gap-8 text-gray-600 text-sm leading-relaxed">
      <div class="space-y-4">
        <p>
          Un buen diseño E-R es el punto de partida que determina la calidad de toda
          la base de datos. En SprintDev Bank, modelar <strong>producto_financiero</strong>
          como entidad padre con herencia lógica permitió que cuenta, tarjeta y crédito
          compartan número de producto y estado sin duplicar lógica ni atributos.
        </p>
        <p>
          La normalización hasta 3FN eliminó las redundancias: separar
          <strong>estado_producto</strong>, <strong>canal</strong> y
          <strong>estado_alerta</strong> en tablas maestras evita anomalías de
          actualización cuando cambia el nombre de un estado.
        </p>
      </div>
      <div class="space-y-4">
        <p>
          La autorrelación en <strong>transaccion</strong> (id_transaccion_original) es
          un ejemplo directo de cómo el modelo E-R guía decisiones que el diseño
          relacional implementa con una FK a la misma tabla.
        </p>
        <p>
          Finalmente, los constraints <code>CHECK</code> y <code>UNIQUE</code> encapsulan
          reglas de negocio directamente en el esquema, garantizando integridad sin
          depender de la capa de aplicación — algo posible gracias a un diseño
          conceptual sólido desde el inicio.
        </p>
      </div>
    </div>
  </article>

</section>

<script type="module">
import mermaid from 'https://esm.sh/mermaid@11/dist/mermaid.esm.min.mjs';
const dark = matchMedia('(prefers-color-scheme: dark)').matches;
await document.fonts.ready;
mermaid.initialize({
  startOnLoad: false,
  theme: 'base',
  fontFamily: 'ui-sans-serif, system-ui, sans-serif',
  themeVariables: {
    darkMode: dark,
    fontSize: '12px',
    lineColor: dark ? '#9c9a92' : '#73726c',
    textColor: dark ? '#c2c0b6' : '#3d3d3a',
    primaryColor: dark ? '#2e1065' : '#f3e8ff',
    primaryTextColor: dark ? '#d8b4fe' : '#6b21a8',
    primaryBorderColor: dark ? '#7c3aed' : '#c4b5fd',
  },
});

const diagram = `erDiagram
  CLIENTE {
    bigint id_cliente PK
    varchar tipo_documento
    varchar numero_documento
    varchar nombres
    varchar apellidos
    varchar estado_cliente
    date fecha_alta
  }
  EMPLEADO {
    bigint id_empleado PK
    varchar nombres
    varchar apellidos
    varchar cargo
    varchar estado_empleado
  }
  CANAL {
    smallint id_canal PK
    varchar nombre
    varchar descripcion
  }
  ESTADO_PRODUCTO {
    smallint id_estado_producto PK
    varchar nombre_estado
  }
  PRODUCTO_FINANCIERO {
    bigint id_producto PK
    bigint id_cliente FK
    smallint id_estado_producto FK
    varchar numero_producto
    date fecha_creacion
  }
  CUENTA {
    bigint id_producto FK
    varchar tipo_cuenta
    numeric saldo_actual
    varchar moneda
  }
  TARJETA {
    bigint id_producto FK
    varchar tipo_tarjeta
    varchar numero_enmascarado
    date fecha_vencimiento
    numeric cupo
  }
  CREDITO {
    bigint id_producto FK
    varchar tipo_credito
    numeric monto_aprobado
    numeric saldo_pendiente
    numeric tasa_interes
  }
  ESTADO_TRANSACCION {
    smallint id_estado_transaccion PK
    varchar nombre_estado
  }
  TRANSACCION {
    bigint id_transaccion PK
    bigint id_cliente FK
    smallint id_estado_transaccion FK
    smallint id_canal FK
    bigint id_transaccion_original FK
    varchar tipo_transaccion
    numeric monto
    boolean es_fallida
  }
  REGLA_FRAUDE {
    bigint id_regla PK
    varchar nombre
    varchar tipo_regla
    numeric umbral
    smallint ventana_minutos
    boolean activa
  }
  ESTADO_ALERTA {
    smallint id_estado_alerta PK
    varchar nombre_estado
  }
  ALERTA_FRAUDE {
    bigint id_alerta PK
    bigint id_regla FK
    smallint id_estado_alerta FK
    varchar tipo_alerta
    varchar severidad
    timestamp fecha_hora
  }
  ALERTA_TRANSACCION {
    bigint id_alerta FK
    bigint id_transaccion FK
    timestamp fecha_asociacion
  }
  EVENTO_AUDITORIA {
    bigint id_evento PK
    bigint id_cliente FK
    bigint id_empleado FK
    smallint id_canal FK
    varchar tipo_responsable
    varchar accion
    timestamp fecha_hora
  }

  CLIENTE ||--o{ PRODUCTO_FINANCIERO : "poseer"
  ESTADO_PRODUCTO ||--o{ PRODUCTO_FINANCIERO : "clasificar"
  PRODUCTO_FINANCIERO ||--o| CUENTA : "extender"
  PRODUCTO_FINANCIERO ||--o| TARJETA : "extender"
  PRODUCTO_FINANCIERO ||--o| CREDITO : "extender"
  CLIENTE ||--o{ TRANSACCION : "realizar"
  ESTADO_TRANSACCION ||--o{ TRANSACCION : "clasificar"
  CANAL ||--o{ TRANSACCION : "originar"
  TRANSACCION ||--o{ TRANSACCION : "revertir"
  REGLA_FRAUDE ||--o{ ALERTA_FRAUDE : "generar"
  ESTADO_ALERTA ||--o{ ALERTA_FRAUDE : "clasificar"
  ALERTA_FRAUDE ||--|{ ALERTA_TRANSACCION : "asociar"
  TRANSACCION ||--|{ ALERTA_TRANSACCION : "pertenecer"
  CLIENTE ||--o{ EVENTO_AUDITORIA : "registrar"
  EMPLEADO ||--o{ EVENTO_AUDITORIA : "registrar"
  CANAL ||--o{ EVENTO_AUDITORIA : "registrar"
`;

try {
  const { svg } = await mermaid.render('mer-sprintdev-svg', diagram);
  document.getElementById('mer-sprintdev').innerHTML = svg;
} catch (e) {
  document.getElementById('mer-sprintdev').innerHTML =
    '<p class="text-gray-400 text-sm">No se pudo renderizar el diagrama.</p>';
}
</script>

</BaseLayout>